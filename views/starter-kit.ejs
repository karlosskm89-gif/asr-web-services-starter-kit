<%
  const profiles = builder?._availableProfiles || [];
  const profileGroups = [
    { title: "Service businesses", items: ["plasterer", "accountant", "consultant", "solicitor"] },
    { title: "Food and hospitality", items: ["cafeDemo", "restaurant", "takeAway"] },
    { title: "Creative and personal brands", items: ["artist", "author", "painter", "photographer", "band", "dj"] },
    { title: "Wellness, coaching and community", items: ["lifeCoach", "musicLessons", "sportCoach", "charity", "clubs"] },
  ];
%>

<%- include("./layouts/mainLayout", {
  title: typeof title !== "undefined" ? title : "ASR Web Services Starter Kit",
  metaDescription: typeof metaDescription !== "undefined"
    ? metaDescription
    : "Profile-driven Express and EJS starter system for small-business websites and enquiry-focused demos.",
  builder,
  currentPath: "starter-kit",
  body: `
<section class="section starter-hero">
  <div class="container starter-grid">
    <div>
      <p class="eyebrow">ASR technical showcase</p>
      <h1>ASR Web Services Starter Kit</h1>
      <p class="lead">A practical Express/EJS foundation for service-business websites, enquiry flows and reusable public demos.</p>
      <div class="hero-badges">
        <span>Express</span>
        <span>EJS</span>
        <span>Profile-driven content</span>
        <span>Modular CSS</span>
      </div>
    </div>
    <aside class="starter-panel">
      <h2>Current demo profile</h2>
      <p><code>TEMPLATE_PROFILE=${builder?._profileKey || "asrWebServices"}</code></p>
      <p>Switch the profile value to preview a different business type while keeping the same routes, views and maintainable structure.</p>
    </aside>
  </div>
</section>

<section class="section alt">
  <div class="container">
    <div class="section-heading">
      <h2>What this starter kit gives a buyer</h2>
      <p>A clear example of how ASR builds websites that can be understood, maintained and extended.</p>
    </div>
    <div class="grid services-grid">
      <div class="service-card"><h3>Reusable page structure</h3><p>Shared EJS layouts and partials power home, about, services, portfolio, FAQ, testimonials, and contact pages.</p></div>
      <div class="service-card"><h3>Profile-driven content</h3><p>Business identity, page copy, services, projects, testimonials, SEO text, and theme choices come from profile modules.</p></div>
      <div class="service-card"><h3>Inquiry-ready foundation</h3><p>Includes contact validation, CSRF protection, rate limiting, security headers, and deployment-friendly health checks.</p></div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-heading">
      <h2>Example profile families</h2>
      <p>A quick look at the business types this structure can support without rebuilding from scratch.</p>
    </div>
    <div class="grid project-grid">
      ${profileGroups.map(group => `
        <div class="project-card starter-profile-card">
          <div class="project-card-body">
            <h3>${group.title}</h3>
            <p>${group.items.filter(item => profiles.includes(item)).join(", ") || "Demo profiles available in modules/"}</p>
          </div>
        </div>
      `).join("")}
    </div>
  </div>
</section>


<section class="section">
  <div class="container starter-docs-grid">
    <div>
      <p class="eyebrow">Built from real project patterns</p>
      <h2>Technical starter first, client proof elsewhere</h2>
      <p>This starter stays focused on the reusable build. Full ASR case studies belong on the ASR website, where buyers can read the project story without mixing it into the codebase.</p>
      <a class="btn primary" href="/portfolio">View portfolio examples</a>
    </div>
    <div class="starter-panel">
      <h3>Why they are separate</h3>
      <ul class="plain-list">
        <li>Keeps the repo lightweight and reusable</li>
        <li>Avoids mixing client proof with starter architecture</li>
        <li>Lets asrweb.ie act as the polished proof layer</li>
        <li>Protects public/private publishing boundaries</li>
      </ul>
    </div>
  </div>
</section>

<section class="section alt">
  <div class="container starter-docs-grid">
    <div>
      <h2>Ready for public portfolio review</h2>
      <p>This public version shows the shape of the work without exposing private client code, production data, credentials or sensitive assets.</p>
    </div>
    <div class="starter-panel">
      <h3>Useful docs</h3>
      <ul class="plain-list">
        <li><code>README.md</code> — public project overview</li>
        <li><code>docs/profile-switching.md</code> — how profile loading works</li>
        <li><code>docs/public-portfolio-notes.md</code> — what stays public vs private</li>
        <li><code>docs/mockup-fictionalisation.md</code> — how branded mockups should be cleaned before publication</li>
        <li><a href="/showcase-mode">/showcase-mode</a> — public use cases and mockup strategy</li>
      </ul>
    </div>
  </div>
</section>
`
}) %>
