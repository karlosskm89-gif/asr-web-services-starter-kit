<section class="page-hero project-hero">
  <div class="container">
    <p class="breadcrumb">
      <a href="/portfolio" class="breadcrumb-link">&larr; Back to portfolio</a>
    </p>

    <h1 class="project-title">
      <%= project.title %>
    </h1>

    <% if (project.subtitle) { %>
      <p class="project-subtitle">
        <%= project.subtitle %>
      </p>
    <% } %>
  </div>
</section>

<section class="project-detail">
  <div class="container project-detail-inner">
    <% if (project.image) { %>
      <div class="project-detail-media">
        <img
          src="<%= project.image %>"
          alt="<%= project.title %>"
          class="project-hero-image"
          loading="lazy"
        />
      </div>
    <% } %>

    <div class="project-detail-content">
      <% if (project.description || project.shortDescription) { %>
        <p class="project-intro">
          <%= project.description || project.shortDescription %>
        </p>
      <% } %>

      <% if (project.longDescription) { %>
        <div class="project-body">
          <p><%= project.longDescription %></p>
        </div>
      <% } %>

      <% if (project.features && project.features.length) { %>
        <div class="project-features">
          <h2>What we did</h2>
          <ul>
            <% project.features.forEach(function (feature) { %>
              <li><%= feature %></li>
            <% }); %>
          </ul>
        </div>
      <% } %>

      <% if (project.location || project.industry || project.year) { %>
        <dl class="project-meta">
          <% if (project.location) { %>
            <div>
              <dt>Location</dt>
              <dd><%= project.location %></dd>
            </div>
          <% } %>
          <% if (project.industry) { %>
            <div>
              <dt>Industry</dt>
              <dd><%= project.industry %></dd>
            </div>
          <% } %>
          <% if (project.year) { %>
            <div>
              <dt>Year</dt>
              <dd><%= project.year %></dd>
            </div>
          <% } %>
        </dl>
      <% } %>

      <% if (project.tags && project.tags.length) { %>
        <div class="project-tags">
          <h3>Tags</h3>
          <ul class="tag-list">
            <% project.tags.forEach(function (tag) { %>
              <li class="tag-pill"><%= tag %></li>
            <% }); %>
          </ul>
        </div>
      <% } %>

      <div class="project-detail-actions">
        <% if (project.link) { %>
          <a
            href="<%= project.link %>"
            class="btn btn-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            View live project
          </a>
        <% } %>

        <a href="/contact" class="btn btn-secondary">
          Start a project like this
        </a>
      </div>
    </div>
  </div>
</section>
