<% const chromeBuilder = (typeof shellBuilder !== "undefined" && shellBuilder) ? shellBuilder : builder; %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title><%= title || chromeBuilder?.businessName || builder?.businessName || "ASR Web Services Starter Kit" %></title>
  <meta
    name="description"
    content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'Public-safe ASR starter kit showing adaptable service-business website foundations, industry examples, enquiry paths and maintainable structure.' %>"
  />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="index,follow" />
  <link rel="canonical" href="<%= typeof canonicalUrl !== 'undefined' && canonicalUrl ? canonicalUrl : 'https://asr-web-services-starter-kit.onrender.com/' %>" />

  <meta property="og:site_name" content="ASR Web Services" />
  <meta property="og:title" content="<%= typeof title !== 'undefined' && title ? title + ' | ASR Web Services Starter Kit' : 'ASR Web Services Starter Kit' %>" />
  <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'Public-safe ASR starter kit showing adaptable service-business website foundations, industry examples, enquiry paths and maintainable structure.' %>" />
  <meta property="og:url" content="<%= typeof canonicalUrl !== 'undefined' && canonicalUrl ? canonicalUrl : 'https://asr-web-services-starter-kit.onrender.com/' %>" />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://asr-web-services-starter-kit.onrender.com/assets/asr-assets/asr-starter-kit.webp/">

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="<%= typeof title !== 'undefined' && title ? title + ' | ASR Web Services Starter Kit' : 'ASR Web Services Starter Kit' %>" />
  <meta name="twitter:description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'Public-safe ASR starter kit showing adaptable service-business website foundations, industry examples, enquiry paths and maintainable structure.' %>" />
  <meta name="twitter:image" content="https://asr-web-services-starter-kit.onrender.com/img/asr-og-portfolio-mountain-qr.webp" />
  <meta name="twitter:creator" content="@asrweb" />

  <link rel="icon" href="/favicon.ico" sizes="any" />

  <!-- Global CSS -->
  <link rel="stylesheet" href="/css/index.css" />

  <!-- Optional module-specific CSS. Loaded before the final ASR alignment pass. -->
<% if (typeof pageCss !== "undefined" && pageCss) { %>
  <link rel="stylesheet" href="<%= pageCss %>">
<% } %>

  <!-- Final ecosystem alignment layer: must remain after every profile/theme stylesheet. -->
  <link rel="stylesheet" href="/css/30-pages/asr-ecosystem-alignment.css">
</head>
<body class="
  profile-<%= builder?._profileKey || 'default' %>
  theme-<%= builder?.themeKey || 'default' %>
  layout-<%= (typeof design !== 'undefined' && design?.layout) ? design.layout : 'balanced' %>
  grid-<%= (typeof design !== 'undefined' && design?.grid) ? design.grid : '3' %>
  nav-<%= (typeof design !== 'undefined' && design?.nav) ? design.nav : 'default' %>
  cards-<%= (typeof design !== 'undefined' && design?.cards) ? design.cards : 'soft' %>
  bg-<%= (typeof design !== 'undefined' && design?.background) ? design.background : 'clean' %>
  font-<%= (typeof design !== 'undefined' && design?.font) ? design.font : 'system' %>
  buttons-<%= (typeof design !== 'undefined' && design?.buttons) ? design.buttons : 'rounded' %>
  hero-<%= (typeof design !== 'undefined' && design?.hero) ? design.hero : 'split' %>
  images-<%= (typeof design !== 'undefined' && design?.images) ? design.images : 'framed' %>
  rhythm-<%= (typeof design !== 'undefined' && design?.rhythm) ? design.rhythm : 'alternating' %>
  sections-<%= (typeof design !== 'undefined' && design?.sections) ? design.sections : 'standard' %>
  cta-<%= (typeof design !== 'undefined' && design?.cta) ? design.cta : 'direct' %>
">
  <header class="site-header">
    <div class="container header-inner">
      <div class="header-brand">
        <a href="/" class="brand-link">
          <% if (chromeBuilder?.brandLogo) { %>
            <img class="brand-logo" src="<%= chromeBuilder.brandLogo %>" alt="<%= chromeBuilder?.businessName || 'Business' %> logo">
          <% } %>
          <span class="brand-text">
            <span class="brand-name"><%= chromeBuilder?.businessName || "Your Business Name" %></span>
            <% if (chromeBuilder?.area) { %>
              <span class="brand-area"><%= chromeBuilder.area %></span>
            <% } %>
          </span>
        </a>
      </div>

      <nav class="main-nav" aria-label="Demo navigation">
        <a href="/" class="<%= currentPath === 'home' ? 'active' : '' %>">Overview</a>
        <a href="/starter-kit" class="<%= currentPath === 'starter-kit' ? 'active' : '' %>">Foundation</a>
        <a href="/showcase-mode" class="<%= currentPath === 'showcase-mode' ? 'active' : '' %>">Industry Examples</a>
        <a href="/portfolio" class="<%= currentPath === 'portfolio' ? 'active' : '' %>">Example Pages</a>
        <a href="https://asrweb.ie/portfolio" target="_blank" rel="noopener">Back to ASR Portfolio</a>
      </nav>

      <div class="header-cta">
        <a class="header-button" href="https://asrweb.ie/contact" target="_blank" rel="noopener">Discuss a real project</a>
      </div>
    </div>
  </header>

  <div class="asr-demo-ribbon" role="note">
    <div class="container asr-demo-ribbon-inner">
      <span>Public-safe ASR proof asset: reusable website foundation, industry examples and enquiry-flow structure.</span>
      <a href="https://asrweb.ie/portfolio" target="_blank" rel="noopener">View ASR portfolio →</a>
    </div>
  </div>

  <main>
    <%- body %>
  </main>

  <footer class="site-footer">
    <% if (chromeBuilder?.footerStrip) { %>
      <div class="footer-strip" aria-hidden="true">
        <img src="<%= chromeBuilder.footerStrip %>" alt="" role="presentation" loading="lazy">
      </div>
    <% } %>

    <div class="container footer-inner">
      <div class="footer-brand-block">
        <% if (chromeBuilder?.brandLogo) { %>
          <img class="footer-logo" src="<%= chromeBuilder.brandLogo %>" alt="<%= chromeBuilder?.businessName || 'Business' %> logo">
        <% } %>
        <div>
          <strong><%= chromeBuilder?.businessName || "Your Business Name" %></strong>
          <p>Public-safe demo of reusable website foundations. The main ASR website remains the sales and contact layer.</p>
          <% if (chromeBuilder?.area) { %><p><%= chromeBuilder.area %></p><% } %>
        </div>
      </div>

      <div class="footer-links">
        <strong>Demo</strong>
        <a href="/">Overview</a>
        <a href="/starter-kit">Foundation</a>
        <a href="/showcase-mode">Industry Examples</a>
        <a href="/portfolio">Example Pages</a>
      </div>

      <div class="footer-links">
        <strong>ASR ecosystem</strong>
        <a href="https://asrweb.ie" target="_blank" rel="noopener">Main ASR website</a>
        <a href="https://asrweb.ie/portfolio" target="_blank" rel="noopener">Portfolio</a>
        <a href="https://asr-operational-systems-demo.onrender.com/" target="_blank" rel="noopener">Operational demo</a>
      </div>

      <div class="footer-links">
        <strong>Real project enquiries</strong>
        <a href="https://asrweb.ie/contact" target="_blank" rel="noopener">Contact ASR</a>
        <a href="https://asrweb.ie/services" target="_blank" rel="noopener">ASR services</a>
        <a href="https://asrweb.ie/case-studies" target="_blank" rel="noopener">Case studies</a>
      </div>
    </div>

    <div class="container footer-bottom">
      <p>ASR foundation proof asset • Practical. Maintainable. Purpose-built.</p>
      <p class="footer-copy">
        &copy; <%= new Date().getFullYear() %>
        <%= chromeBuilder?.businessName || "Your Business Name" %>. All rights reserved.
      </p>

      <% if (builder?._profileKey || (builder?._availableProfiles && builder._availableProfiles.length)) { %>
        <small class="footer-profile-meta">
          <% if (builder?._profileKey) { %>
            <span class="profile-label">
              Active example:
              <strong><%= builder._profileKey %></strong>
            </span>
          <% } %>

          <% if (
            builder?._availableProfiles &&
            builder._availableProfiles.length &&
            typeof isDev !== "undefined" &&
            isDev
          ) { %>
            <span class="profile-switch-hint">
              (Switch with
              <code>
                TEMPLATE_PROFILE=<%= builder._availableProfiles.join("|") %>
              </code>
              in your .env)
            </span>
          <% } %>
        </small>
      <% } %>
    </div>
  </footer>
  <script src="/js/configurator.js" defer></script>
</body>
</html>
