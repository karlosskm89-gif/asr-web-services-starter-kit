<% const chromeBuilder = (typeof shellBuilder !== "undefined" && shellBuilder) ? shellBuilder : builder; %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title><%= title || chromeBuilder?.businessName || builder?.businessName || "ASR Web Services Starter Kit" %></title>
  <meta
    name="description"
    content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'Adaptable small-business website starter kit, Profile Lab and public-safe ASR demo ecosystem.' %>"
  />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="index,follow" />
  <link rel="canonical" href="<%= typeof canonicalUrl !== 'undefined' && canonicalUrl ? canonicalUrl : 'https://asr-web-services-starter-kit.onrender.com/' %>" />

  <meta property="og:site_name" content="ASR Web Services" />
  <meta property="og:title" content="<%= typeof title !== 'undefined' && title ? title + ' | ASR Web Services Starter Kit' : 'ASR Web Services Starter Kit' %>" />
  <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'Adaptable small-business website starter kit, Profile Lab and public-safe ASR demo ecosystem.' %>" />
  <meta property="og:url" content="<%= typeof canonicalUrl !== 'undefined' && canonicalUrl ? canonicalUrl : 'https://asr-web-services-starter-kit.onrender.com/' %>" />
  <meta property="og:type" content="website" />
  <meta property="og:image" content="https://asr-web-services-starter-kit.onrender.com/img/asr-og-portfolio-mountain-qr.jpg" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="<%= typeof title !== 'undefined' && title ? title + ' | ASR Web Services Starter Kit' : 'ASR Web Services Starter Kit' %>" />
  <meta name="twitter:description" content="<%= typeof metaDescription !== 'undefined' && metaDescription ? metaDescription : 'Adaptable small-business website starter kit, Profile Lab and public-safe ASR demo ecosystem.' %>" />
  <meta name="twitter:image" content="https://asr-web-services-starter-kit.onrender.com/img/asr-og-portfolio-mountain-qr.jpg" />
  <meta name="twitter:creator" content="@asrweb" />

  <link rel="icon" href="/favicon.ico" sizes="any" />

  <!-- Global CSS -->
  <link rel="stylesheet" href="/css/index.css" />

  <!-- Optional module-specific CSS -->
<% if (typeof pageCss !== "undefined" && pageCss) { %>
  <link rel="stylesheet" href="<%= pageCss %>">
<% } %>
</head>
<body class="
  profile-<%= builder?._profileKey || 'default' %>
  theme-<%= builder?.themeKey || 'default' %>
">
  <header class="site-header">
    <div class="container header-inner">
      <div class="header-brand">
        <a href="/" class="brand-link">
          <% if (chromeBuilder?.brandLogo) { %>
            <img class="brand-logo" src="<%= chromeBuilder.brandLogo %>" alt="<%= chromeBuilder?.businessName || 'Business' %> logo">
          <% } %>
          <span class="brand-text">
            <span class="brand-name"><%= chromeBuilder?.businessName || "Your Business Name" %></span>
            <% if (chromeBuilder?.area) { %>
              <span class="brand-area"><%= chromeBuilder.area %></span>
            <% } %>
          </span>
        </a>
      </div>

      <nav class="main-nav" aria-label="Main navigation">
        <a href="/" class="<%= currentPath === 'home' ? 'active' : '' %>">Home</a>
        <a href="/about" class="<%= currentPath === 'about' ? 'active' : '' %>">About</a>
        <a href="/services" class="<%= currentPath === 'services' ? 'active' : '' %>">Services</a>
        <a href="/portfolio" class="<%= currentPath === 'portfolio' ? 'active' : '' %>">Portfolio</a>
        <a href="/starter-kit" class="<%= currentPath === 'starter-kit' ? 'active' : '' %>">Starter Kit</a>
        <a href="/showcase-mode" class="<%= currentPath === 'showcase-mode' ? 'active' : '' %>">Profile Lab</a>
        <a href="/testimonials" class="<%= currentPath === 'testimonials' ? 'active' : '' %>">Client Signals</a>
        <a href="/faqs" class="<%= currentPath === 'faqs' ? 'active' : '' %>">FAQ</a>
        <a href="/contact" class="<%= currentPath === 'contact' ? 'active' : '' %>">Contact</a>
      </nav>

      <div class="header-cta">
        <% if (chromeBuilder?.phone) { %>
          <a class="header-phone" href="tel:<%= chromeBuilder.phone %>">
            Call: <%= chromeBuilder.phone %>
          </a>
        <% } else if (chromeBuilder?.ctaButtonText) { %>
          <a class="header-button" href="/contact"><%= chromeBuilder.ctaButtonText %></a>
        <% } %>
      </div>
    </div>
  </header>

  <main>
    <%- body %>
  </main>

  <footer class="site-footer">
    <% if (chromeBuilder?.footerStrip) { %>
      <div class="footer-strip" aria-hidden="true">
        <img src="<%= chromeBuilder.footerStrip %>" alt="" role="presentation" loading="lazy">
      </div>
    <% } %>

    <div class="container footer-inner">
      <div class="footer-brand-block">
        <% if (chromeBuilder?.brandLogo) { %>
          <img class="footer-logo" src="<%= chromeBuilder.brandLogo %>" alt="<%= chromeBuilder?.businessName || 'Business' %> logo">
        <% } %>
        <div>
          <strong><%= chromeBuilder?.businessName || "Your Business Name" %></strong>
          <p>Practical websites and digital systems for real organisations.</p>
          <% if (chromeBuilder?.area) { %><p><%= chromeBuilder.area %></p><% } %>
        </div>
      </div>

      <div class="footer-links">
        <strong>Quick Links</strong>
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/services">Services</a>
        <a href="/portfolio">Portfolio</a>
        <a href="/starter-kit">Starter Kit</a>
        <a href="/showcase-mode">Profile Lab</a>
      </div>

      <div class="footer-links">
        <strong>Resources</strong>
        <a href="/testimonials">Client Signals</a>
        <a href="/faqs">FAQ</a>
        <a href="/contact">Contact</a>
      </div>

      <div class="footer-links">
        <strong>Connect</strong>
        <% if (chromeBuilder?.email) { %><a href="mailto:<%= chromeBuilder.email %>"><%= chromeBuilder.email %></a><% } %>
        <% if (chromeBuilder?.website) { %><a href="<%= chromeBuilder.website %>"><%= chromeBuilder.website.replace(/^https?:\/\//, '') %></a><% } %>
        <% if (chromeBuilder?.area) { %><span><%= chromeBuilder.area %></span><% } %>
      </div>
    </div>

    <div class="container footer-bottom">
      <p>Built by ASR Web Services • Practical. Maintainable. Purpose-built.</p>
      <p class="footer-copy">
        &copy; <%= new Date().getFullYear() %>
        <%= chromeBuilder?.businessName || "Your Business Name" %>. All rights reserved.
      </p>

      <% if (builder?._profileKey || (builder?._availableProfiles && builder._availableProfiles.length)) { %>
        <small class="footer-profile-meta">
          <% if (builder?._profileKey) { %>
            <span class="profile-label">
              Profile:
              <strong><%= builder._profileKey %></strong>
            </span>
          <% } %>

          <% if (
            builder?._availableProfiles &&
            builder._availableProfiles.length &&
            typeof isDev !== "undefined" &&
            isDev
          ) { %>
            <span class="profile-switch-hint">
              (Switch with
              <code>
                TEMPLATE_PROFILE=<%= builder._availableProfiles.join("|") %>
              </code>
              in your .env)
            </span>
          <% } %>
        </small>
      <% } %>
    </div>
  </footer>
</body>
</html>
