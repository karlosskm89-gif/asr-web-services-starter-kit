<%
  const hero = builder?.hero || {};
  const services = builder?.services || [];
  const projects = builder?.projects || [];
  const heroImage = builder?.heroImage || builder?.brandLogo || null;
  const featureImage = builder?.featureImage || null;
%>

<%- include("./layouts/mainLayout", {
  title: typeof title !== "undefined" ? title : (builder?.businessName || "Welcome"),
  metaDescription: typeof metaDescription !== "undefined"
    ? metaDescription
    : (builder?.seo?.metaDescription || ""),
  builder,
  currentPath: "home",
  body: `
<section class="hero hero-split">
  <div class="container hero-grid">
    <div class="hero-copy">
      <h1>ASR Service Starter Kit Demo</h1>
      <p>Public-safe proof of reusable website foundations, industry examples and enquiry-flow structure.</p>

      ${hero.badges?.length ? `
        <div class="hero-badges">
          ${hero.badges.map(b => `<span>${b}</span>`).join("")}
        </div>
      ` : ""}

      <div class="hero-ctas">
        <a href="/starter-kit" class="btn primary">View foundation</a>
        <a href="/showcase-mode" class="btn secondary">Explore examples</a>
      </div>
    </div>

    ${heroImage ? `
      <figure class="hero-visual-card">
        <img src="${heroImage}" alt="${builder?.businessName || "Business"} visual identity">
      </figure>
    ` : ""}
  </div>
</section>

<section class="section services-section">
  <div class="container">
    <div class="section-heading">
      <h2>What this system supports</h2>
    </div>
    <div class="grid services-grid">
      ${services.slice(0, 3).map(s => `
        <div class="service-card">
          <h3>${s.title}</h3>
          <p>${s.description}</p>
        </div>
      `).join("")}
    </div>
  </div>
</section>

${featureImage ? `
<section class="section contact-feature-section">
  <div class="container contact-feature-grid">
    <div class="contact-feature-card">
      <h2>Need the actual ASR site?</h2>
      <p>This is a demo environment. For services, case studies and project enquiries, use the main ASR website.</p>
      <a href="https://asrweb.ie" class="btn secondary">Open asrweb.ie</a>
    </div>
    <figure class="contact-feature-image">
      <img src="${featureImage}" alt="ASR mountain frame visual">
    </figure>
    <div class="contact-feature-card">
      <h2>Want to discuss a real project?</h2>
      <p>Use the main ASR contact route so this demo stays focused on proof, not sales.</p>
      <a href="https://asrweb.ie/contact" class="btn primary">Contact ASR</a>
    </div>
  </div>
</section>
` : ""}



<section class="section alt">
  <div class="container">
    <div class="section-heading">
      <h2>Practical proof points</h2>
    </div>
    <div class="grid project-grid">
      ${projects.map(p => `
        <div class="project-card">
          <img src="${p.image || "/assets/img/placeholder.webp"}" alt="${p.title}">
          <div class="project-card-body">
            <h3>${p.title}</h3>
            ${p.summary ? `<p>${p.summary}</p>` : ""}
          </div>
        </div>
      `).join("")}
    </div>
  </div>
</section>
`
}) %>
