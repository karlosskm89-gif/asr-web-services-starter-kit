<%
  function escAttr(value) {
    return String(value || "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  const oldValues = old || {};
  const errors = validationErrors || [];

  function fieldError(path) {
    return errors.find(function (e) { return e.path === path; });
  }
%>

<%- include("./layouts/mainLayout", {
  title: typeof title !== "undefined" ? title : "Use the main ASR contact route",
  metaDescription: typeof metaDescription !== "undefined"
    ? metaDescription
    : (builder?.seo?.contactDescription || builder?.seo?.metaDescription || ""),
  builder,
  currentPath: "contact",
  body: `
<section class="section">
  <div class="container">
    <h1>This demo does not collect project enquiries</h1>
    <p>
      The Starter Kit is a public-safe proof asset. For real project conversations,
      use the main ASR Web Services contact page.
    </p>
    <p>
      Keeping enquiries on the main website prevents this demo from behaving like a second ASR website.
    </p>
    <a class="btn primary" href="https://asrweb.ie/contact" target="_blank" rel="noopener">Use main ASR contact on the main website</a>
    <a class="btn secondary" href="/showcase-mode">Return to industry examples</a>
  </div>
</section>
`
}) %>
