<%
  const studies = Array.isArray(caseStudies) ? caseStudies : [];
%>

<%- include("./layouts/mainLayout", {
  title: typeof title !== "undefined" ? title : "Case Studies",
  metaDescription: typeof metaDescription !== "undefined"
    ? metaDescription
    : "Public-safe case-study narratives for ASR Web Services Starter Kit.",
  builder,
  currentPath: "case-studies",
  body: `
<section class="section case-study-hero">
  <div class="container starter-grid">
    <div>
      <p class="eyebrow">Public-safe proof layer</p>
      <h1>Case studies without exposing private code</h1>
      <p class="lead">These pages explain the business problems, system patterns, and delivery thinking behind selected work while keeping production repositories, client data, admin screens, and private implementation details protected.</p>
      <div class="hero-badges">
        <span>Public narrative</span>
        <span>Private code protected</span>
        <span>Business outcomes</span>
      </div>
    </div>
    <aside class="starter-panel">
      <h2>Why this section exists</h2>
      <p>Some of the strongest ASR work is real client work that should not be open-sourced. This section gives safe context without turning private systems into public repositories.</p>
    </aside>
  </div>
</section>

<section class="section alt">
  <div class="container">
    <div class="section-heading">
      <h2>Selected public-safe narratives</h2>
      <p>Each case study focuses on the problem, solution pattern, key features, stack, and privacy boundary.</p>
    </div>
    <div class="grid case-study-grid">
      ${studies.map(item => `
        <article class="case-study-card">
          <p class="eyebrow">${item.category}</p>
          <h3><a href="/case-studies/${item.slug}">${item.title}</a></h3>
          <p>${item.summary}</p>
          <p class="showcase-status"><strong>Status:</strong> ${item.status}</p>
          <a class="text-link" href="/case-studies/${item.slug}">Read case study →</a>
        </article>
      `).join("")}
    </div>
  </div>
</section>

<section class="section">
  <div class="container starter-docs-grid">
    <div>
      <h2>The publishing boundary</h2>
      <p>This starter kit can show structure, patterns, documentation habits, and public-safe narrative proof. It should not expose real client code, databases, form submissions, credentials, or private admin implementation.</p>
    </div>
    <div class="starter-panel">
      <h3>Safe to publish</h3>
      <ul class="plain-list">
        <li>Business problem summaries</li>
        <li>High-level system patterns</li>
        <li>Public website screenshots</li>
        <li>Fictionalised mockups</li>
        <li>Generic starter-kit code</li>
      </ul>
    </div>
  </div>
</section>
`
}) %>
