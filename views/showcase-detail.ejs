<%- include("./layouts/mainLayout", {
  title: typeof title !== "undefined" ? title : item.title,
  metaDescription: typeof metaDescription !== "undefined" ? metaDescription : item.summary,
  builder,
  currentPath: "showcase",
  body: `
<section class="section showcase-detail-hero">
  <div class="container starter-grid">
    <div>
      <p class="eyebrow">${item.category}</p>
      <h1>${item.title}</h1>
      <p class="lead">${item.summary}</p>
      <div class="hero-badges">
        <span>${item.status}</span>
        <span>Public-safe</span>
        <span>Portfolio example</span>
      </div>
    </div>
    <aside class="starter-panel">
      <h2>What it demonstrates</h2>
      <ul class="plain-list">
        ${item.demonstrates.map(point => `<li>${point}</li>`).join("")}
      </ul>
    </aside>
  </div>
</section>

<section class="section alt">
  <div class="container showcase-detail-grid">
    <div class="showcase-preview-frame">
      <img src="${item.screenshot}" alt="${item.title} page preview">
    </div>
    <div>
      <h2>Problem</h2>
      <p>${item.problem}</p>
      <h2>Solution pattern</h2>
      <p>${item.solution}</p>
      <p class="note-card">${item.publicNote}</p>
    </div>
  </div>
</section>

<section class="section">
  <div class="container starter-docs-grid">
    <div>
      <h2>Typical sections</h2>
      <ul class="plain-list feature-list">
        ${item.sections.map(section => `<li>${section}</li>`).join("")}
      </ul>
    </div>
    <div class="starter-panel">
      <h3>How this fits the starter kit</h3>
      <p>This item is a showcase layer on top of the reusable Express/EJS profile system. It gives a non-private, public-facing example of the type of structure ASR can adapt for real client projects.</p>
      <a class="text-link" href="/showcase">← Back to showcase</a>
    </div>
  </div>
</section>
`
}) %>
