<%
  const items = Array.isArray(showcaseItems) ? showcaseItems : [];
  const cases = Array.isArray(useCases) ? useCases : [];
%>

<%- include("./layouts/mainLayout", {
  title: typeof title !== "undefined" ? title : "Showcase & Use Cases",
  metaDescription: typeof metaDescription !== "undefined"
    ? metaDescription
    : "Example use cases and public-safe showcase concepts for the ASR Web Services Starter Kit.",
  builder,
  currentPath: "showcase",
  body: `
<section class="section showcase-hero">
  <div class="container starter-grid">
    <div>
      <p class="eyebrow">Public portfolio layer</p>
      <h1>Showcase & use cases</h1>
      <p class="lead">This section shows how the starter kit can support proposal work, public portfolio examples, and fictionalised mockups without exposing private client material.</p>
      <div class="hero-badges">
        <span>Mockups</span>
        <span>Use cases</span>
        <span>Profile variants</span>
        <span>Public-safe demos</span>
      </div>
    </div>
    <aside class="starter-panel">
      <h2>Current state</h2>
      <p>This public version includes five complete fictional showcase examples covering trades, hospitality, creator/personal brand, wellness/private practice, and community organisation use cases. Real client systems, branded proposal work, production data, and private admin logic stay out of this repository.</p>
    </aside>
  </div>
</section>

<section class="section alt">
  <div class="container">
    <div class="section-heading">
      <h2>What this can be used for</h2>
      <p>The starter kit is not just a code sample. It is a reusable presentation and prototyping base.</p>
    </div>
    <div class="grid services-grid showcase-use-grid">
      ${cases.map(item => `
        <article class="service-card">
          <h3>${item.title}</h3>
          <p>${item.text}</p>
        </article>
      `).join("")}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-heading">
      <h2>Public-safe showcase examples</h2>
      <p>These examples show how mockup/proposal thinking can be repackaged safely as fictional portfolio material with reusable business patterns.</p>
    </div>
    <div class="showcase-stack">
      ${items.map(item => `
        <article class="showcase-card">
          <a class="showcase-card-media" href="/showcase/${item.slug}" aria-label="View ${item.title}">
            <img src="${item.image}" alt="${item.title} illustration">
          </a>
          <div class="showcase-card-body">
            <p class="eyebrow">${item.category}</p>
            <h3><a href="/showcase/${item.slug}">${item.title}</a></h3>
            <p>${item.summary}</p>
            <ul class="tag-list">
              ${item.demonstrates.map(tag => `<li>${tag}</li>`).join("")}
            </ul>
            <p class="showcase-status"><strong>Status:</strong> ${item.status}</p>
            <a class="text-link" href="/showcase/${item.slug}">View showcase details →</a>
          </div>
        </article>
      `).join("")}
    </div>
  </div>
</section>

<section class="section alt">
  <div class="container starter-docs-grid">
    <div>
      <h2>Mockup publishing rule</h2>
      <p>Client-specific proposal mockups should be converted into fictional showcase pieces before publication. That means replacing real logos, names, phone numbers, emails, domains, addresses, and brand-specific copy.</p>
      <p>The layout, UX thinking, section structure, and conversion logic can remain. The client identity should not.</p>
    </div>
    <div class="starter-panel">
      <h3>Safe public format</h3>
      <ul class="plain-list">
        <li>Fictional business name</li>
        <li>Placeholder contact details</li>
        <li>Generic logo/visual identity</li>
        <li>Short explanation of what the mockup demonstrates</li>
        <li>Screenshot or live demo once cleaned</li>
      </ul>
    </div>
  </div>
</section>
`
}) %>
