<%
  const items = Array.isArray(profiles) ? profiles : [];
%>

<%- include("./layouts/mainLayout", {
  title: typeof title !== "undefined" ? title : "Industry Examples",
  metaDescription: typeof metaDescription !== "undefined"
    ? metaDescription
    : "Explore example-driven demo variants inside the ASR Web Services Starter Kit.",
  builder,
  currentPath: "showcase-mode",
  body: `
<section class="section showcase-mode-hero">
  <div class="container starter-grid">
    <div>
      <p class="eyebrow">Industry example layer</p>
      <h1>Industry Examples</h1>
      <p class="lead">
        Preview how ASR can shape the same reliable website foundation around different
        service businesses, offers and enquiry journeys.
      </p>
      <div class="hero-badges">
        <span>ASR foundation</span>
        <span>Industry examples</span>
        <span>Public-safe content</span>
        <span>Reusable structure</span>
      </div>
    </div>
    <aside class="starter-panel">
      <h2>How it works</h2>
      <p>
        Choose an industry example and the same ASR foundation reshapes the copy, service cards, project examples and visual tone. It demonstrates adaptable small-business website structure without pretending to be a finished client site.
      </p>
      <a class="text-link" href="/">Main ASR website →</a>
    </aside>

    <aside class="configurator-panel">
      <h2>Try the configurator</h2>
      <p>Change the presentation style without changing the underlying website structure.</p>
      <div class="configurator-groups">
        <div class="configurator-group"><strong>Grid</strong><div class="configurator-options"><a href="?grid=2" data-config-key="grid" data-config-value="2">2 columns</a><a href="?grid=3" data-config-key="grid" data-config-value="3">3 columns</a><a href="?grid=4" data-config-key="grid" data-config-value="4">4 columns</a></div></div>
        <div class="configurator-group"><strong>Cards</strong><div class="configurator-options"><a href="?cards=soft" data-config-key="cards" data-config-value="soft">Soft</a><a href="?cards=sharp" data-config-key="cards" data-config-value="sharp">Sharp</a><a href="?cards=elevated" data-config-key="cards" data-config-value="elevated">Elevated</a></div></div>
        <div class="configurator-group"><strong>Nav</strong><div class="configurator-options"><a href="?nav=default" data-config-key="nav" data-config-value="default">Top</a><a href="?nav=pill" data-config-key="nav" data-config-value="pill">Pill</a><a href="?nav=underline" data-config-key="nav" data-config-value="underline">Underline</a><a href="?nav=boxed" data-config-key="nav" data-config-value="boxed">Boxed</a><a href="?nav=side" data-config-key="nav" data-config-value="side">Side-style</a><a href="?nav=compact" data-config-key="nav" data-config-value="compact">Compact</a><a href="?nav=condensed" data-config-key="nav" data-config-value="condensed">Condensed</a></div></div>
        <div class="configurator-group"><strong>Spacing</strong><div class="configurator-options"><a href="?layout=compact" data-config-key="layout" data-config-value="compact">Compact</a><a href="?layout=balanced" data-config-key="layout" data-config-value="balanced">Balanced</a><a href="?layout=spacious" data-config-key="layout" data-config-value="spacious">Spacious</a></div></div>
        <div class="configurator-group"><strong>Background</strong><div class="configurator-options"><a href="?background=clean" data-config-key="background" data-config-value="clean">Clean</a><a href="?background=paper" data-config-key="background" data-config-value="paper">Paper</a><a href="?background=wash" data-config-key="background" data-config-value="wash">Wash</a></div></div>
        <div class="configurator-group"><strong>Fonts</strong><div class="configurator-options"><a href="?font=system" data-config-key="font" data-config-value="system">System</a><a href="?font=serif" data-config-key="font" data-config-value="serif">Serif headings</a><a href="?font=compact" data-config-key="font" data-config-value="compact">Compact</a></div></div>
        <div class="configurator-group"><strong>Buttons</strong><div class="configurator-options"><a href="?buttons=rounded" data-config-key="buttons" data-config-value="rounded">Rounded</a><a href="?buttons=square" data-config-key="buttons" data-config-value="square">Square</a><a href="?buttons=bold" data-config-key="buttons" data-config-value="bold">Bold</a></div></div>
        <div class="configurator-group"><strong>Hero</strong><div class="configurator-options"><a href="?hero=split" data-config-key="hero" data-config-value="split">Split</a><a href="?hero=centred" data-config-key="hero" data-config-value="centred">Centred</a><a href="?hero=compact" data-config-key="hero" data-config-value="compact">Compact</a></div></div>
        <div class="configurator-group"><strong>Images</strong><div class="configurator-options"><a href="?images=framed" data-config-key="images" data-config-value="framed">Framed</a><a href="?images=full" data-config-key="images" data-config-value="full">Full-bleed</a><a href="?images=minimal" data-config-key="images" data-config-value="minimal">Minimal</a></div></div>
        <div class="configurator-group"><strong>Sections</strong><div class="configurator-options"><a href="?rhythm=alternating" data-config-key="rhythm" data-config-value="alternating">Alternating</a><a href="?rhythm=plain" data-config-key="rhythm" data-config-value="plain">Plain</a><a href="?rhythm=highlighted" data-config-key="rhythm" data-config-value="highlighted">Highlighted</a><a href="?sections=collapsible" data-config-key="sections" data-config-value="collapsible">Collapsible</a></div></div>
        <div class="configurator-group"><strong>CTA tone</strong><div class="configurator-options"><a href="?cta=direct" data-config-key="cta" data-config-value="direct">Direct</a><a href="?cta=soft" data-config-key="cta" data-config-value="soft">Soft</a><a href="?cta=campaign" data-config-key="cta" data-config-value="campaign">Campaign</a></div></div>
      </div>
    </aside>

  </div>
</section>

<section class="section alt">
  <div class="container">
    <div class="section-heading">
      <h2>Explore industry examples</h2>
      <p>
        Each example keeps the same maintainable build underneath, then changes the story, services and buyer journey on top.
      </p>
    </div>

    <div class="grid showcase-mode-grid">
      ${items.map(profile => `
        <article class="showcase-mode-card">
          ${profile.logo ? `
            <figure class="showcase-mode-logo">
              <img src="${profile.logo}" alt="${profile.businessName} visual identity">
            </figure>
          ` : ""}
          <p class="eyebrow">${profile.category}</p>
          <h3>${profile.businessName}</h3>
          ${profile.area ? `<p class="showcase-mode-area">${profile.area}</p>` : ""}
          <p>${profile.summary}</p>
          ${profile.badges?.length ? `
            <ul class="tag-list">
              ${profile.badges.slice(0, 4).map(tag => `<li>${tag}</li>`).join("")}
            </ul>
          ` : ""}
          <a class="btn secondary" href="/showcase-mode/${profile.key}${typeof designQuery !== "undefined" && designQuery ? `?${designQuery}` : ""}">
            Preview profile
          </a>
        </article>
      `).join("")}
    </div>
  </div>
</section>

<section class="section">
  <div class="container starter-docs-grid">
    <div>
      <h2>Why Industry Examples exists</h2>
      <p>
        Most small businesses need the same foundations: clear positioning, service pages,
        trust signals, enquiries and room to grow. The shape changes; the foundation stays calm.
      </p>
      <p>
        This page keeps those options visible without turning the project into a cluttered
        gallery of unrelated mockups.
      </p>
    </div>

    <div class="starter-panel">
      <h3>A useful industry example should show:</h3>
      <ul class="plain-list">
        <li>A clear type of buyer</li>
        <li>A realistic enquiry path</li>
        <li>Reusable page structure</li>
        <li>Clean public-facing sample content</li>
        <li>Business thinking, not just a theme swap</li>
      </ul>
    </div>
  </div>
</section>
`
}) %>
