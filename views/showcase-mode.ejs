<%
  const items = Array.isArray(profiles) ? profiles : [];
%>

<%- include("./layouts/mainLayout", {
  title: typeof title !== "undefined" ? title : "Showcase Mode",
  metaDescription: typeof metaDescription !== "undefined"
    ? metaDescription
    : "Explore profile-driven demo variants inside the ASR Web Services Starter Kit.",
  builder,
  currentPath: "showcase-mode",
  body: `
<section class="section showcase-mode-hero">
  <div class="container starter-grid">
    <div>
      <p class="eyebrow">Profile switching layer</p>
      <h1>Showcase Mode</h1>
      <p class="lead">
        ASR stays as the core identity. Showcase Mode lets you preview how the same
        Express/EJS starter structure adapts across different fictional business profiles.
      </p>
      <div class="hero-badges">
        <span>ASR shell</span>
        <span>Profile-driven demos</span>
        <span>Public-safe examples</span>
        <span>Reusable structure</span>
      </div>
    </div>
    <aside class="starter-panel">
      <h2>How it works</h2>
      <p>
        The app normally loads the ASR profile. In Showcase Mode, a selected demo
        profile is rendered inside the ASR-branded shell to demonstrate modular profile switching
        without pretending these are real client sites.
      </p>
      <a class="text-link" href="/">Return to ASR core →</a>
    </aside>
  </div>
</section>

<section class="section alt">
  <div class="container">
    <div class="section-heading">
      <h2>Choose a showcase profile</h2>
      <p>
        Each profile uses the same underlying structure with different content, positioning,
        service patterns and visual tone.
      </p>
    </div>

    <div class="grid showcase-mode-grid">
      ${items.map(profile => `
        <article class="showcase-mode-card">
          ${profile.logo ? `
            <figure class="showcase-mode-logo">
              <img src="${profile.logo}" alt="${profile.businessName} visual identity">
            </figure>
          ` : ""}
          <p class="eyebrow">${profile.category}</p>
          <h3>${profile.businessName}</h3>
          ${profile.area ? `<p class="showcase-mode-area">${profile.area}</p>` : ""}
          <p>${profile.summary}</p>
          ${profile.badges?.length ? `
            <ul class="tag-list">
              ${profile.badges.slice(0, 4).map(tag => `<li>${tag}</li>`).join("")}
            </ul>
          ` : ""}
          <a class="btn secondary" href="/showcase-mode/${profile.key}">
            Preview profile
          </a>
        </article>
      `).join("")}
    </div>
  </div>
</section>

<section class="section">
  <div class="container starter-docs-grid">
    <div>
      <h2>Why Showcase Mode exists</h2>
      <p>
        The point is not to create a separate gallery of unrelated mockups.
        The point is to show how one maintainable operational foundation can support
        different small-business contexts.
      </p>
      <p>
        This makes the profile-switching system visible and understandable while keeping
        the public-facing identity anchored in ASR Web Services.
      </p>
    </div>

    <div class="starter-panel">
      <h3>Good showcase examples should demonstrate:</h3>
      <ul class="plain-list">
        <li>Different business contexts</li>
        <li>Different enquiry and service patterns</li>
        <li>Reusable layouts and components</li>
        <li>Public-safe fictionalised content</li>
        <li>Operational thinking, not just visual themes</li>
      </ul>
    </div>
  </div>
</section>
`
}) %>
