<%
  const hero = builder?.hero || {};
  const services = builder?.services || [];
  const projects = builder?.projects || [];
  const heroImage = builder?.heroImage || builder?.brandLogo || null;
  const profileList = Array.isArray(profiles) ? profiles : [];
%>

<%- include("./layouts/mainLayout", {
  title: typeof title !== "undefined" ? title : `${builder?.businessName || "Profile"} | Industry Examples`,
  metaDescription: typeof metaDescription !== "undefined"
    ? metaDescription
    : (builder?.seo?.metaDescription || ""),
  builder,
  shellBuilder,
  pageCss,
  currentPath: "showcase-mode",
  body: `
<section class="showcase-mode-banner">
  <div class="container showcase-mode-banner-inner">
    <div>
      <p class="eyebrow">Industry Examples</p>
      <strong>${builder?.businessName || "Industry example"}</strong>
      <span>This is a fictional/public-safe profile rendered inside the ASR starter-kit shell.</span>
    </div>
    <div class="showcase-mode-actions">
      <a href="/showcase-mode" class="text-link">Switch profile</a>
      <a href="/" class="text-link">Return to ASR core</a>
    </div>
  </div>
</section>

<section class="hero hero-split showcase-profile-preview">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">Active profile: ${builder?._profileKey || ""}</p>
      <h1>${hero.headline || builder?.businessName || "Industry example"}</h1>
      <p>${hero.subheadline || builder?.seo?.metaDescription || "Example-driven example content."}</p>

      ${hero.badges?.length ? `
        <div class="hero-badges">
          ${hero.badges.map(b => `<span>${b}</span>`).join("")}
        </div>
      ` : ""}

      <div class="hero-ctas">
        ${builder?.phone ? `<a href="tel:${builder.phone}" class="btn primary">Call Now</a>` : ""}
        <a href="/showcase-mode" class="btn secondary">Choose another example</a>
      </div>
    </div>

    ${heroImage ? `
      <figure class="hero-visual-card">
        <img src="${heroImage}" alt="${builder?.businessName || "Business"} visual identity">
      </figure>
    ` : ""}
  </div>
</section>

<section class="section alt">
  <div class="container">
    <aside class="configurator-panel">
      <h2>Configure this example</h2>
      <p>Keep the same business content and change the presentation style.</p>
      <div class="configurator-groups">
        <div class="configurator-group"><strong>Grid</strong><div class="configurator-options"><a href="?grid=2" data-config-key="grid" data-config-value="2">2 columns</a><a href="?grid=3" data-config-key="grid" data-config-value="3">3 columns</a><a href="?grid=4" data-config-key="grid" data-config-value="4">4 columns</a></div></div>
        <div class="configurator-group"><strong>Cards</strong><div class="configurator-options"><a href="?cards=soft" data-config-key="cards" data-config-value="soft">Soft</a><a href="?cards=sharp" data-config-key="cards" data-config-value="sharp">Sharp</a><a href="?cards=elevated" data-config-key="cards" data-config-value="elevated">Elevated</a></div></div>
        <div class="configurator-group"><strong>Nav</strong><div class="configurator-options"><a href="?nav=default" data-config-key="nav" data-config-value="default">Top</a><a href="?nav=pill" data-config-key="nav" data-config-value="pill">Pill</a><a href="?nav=underline" data-config-key="nav" data-config-value="underline">Underline</a><a href="?nav=boxed" data-config-key="nav" data-config-value="boxed">Boxed</a><a href="?nav=side" data-config-key="nav" data-config-value="side">Side-style</a><a href="?nav=compact" data-config-key="nav" data-config-value="compact">Compact</a><a href="?nav=condensed" data-config-key="nav" data-config-value="collapsible">Condensed</a></div></div>
        <div class="configurator-group"><strong>Spacing</strong><div class="configurator-options"><a href="?layout=compact" data-config-key="layout" data-config-value="compact">Compact</a><a href="?layout=balanced" data-config-key="layout" data-config-value="balanced">Balanced</a><a href="?layout=spacious" data-config-key="layout" data-config-value="spacious">Spacious</a></div></div>
        <div class="configurator-group"><strong>Background</strong><div class="configurator-options"><a href="?background=clean" data-config-key="background" data-config-value="clean">Clean</a><a href="?background=paper" data-config-key="background" data-config-value="paper">Paper</a><a href="?background=wash" data-config-key="background" data-config-value="wash">Wash</a></div></div>
        <div class="configurator-group"><strong>Fonts</strong><div class="configurator-options"><a href="?font=system" data-config-key="font" data-config-value="system">System</a><a href="?font=serif" data-config-key="font" data-config-value="serif">Serif headings</a><a href="?font=compact" data-config-key="font" data-config-value="compact">Compact</a></div></div>
        <div class="configurator-group"><strong>Buttons</strong><div class="configurator-options"><a href="?buttons=rounded" data-config-key="buttons" data-config-value="rounded">Rounded</a><a href="?buttons=square" data-config-key="buttons" data-config-value="square">Square</a><a href="?buttons=bold" data-config-key="buttons" data-config-value="bold">Bold</a></div></div>
        <div class="configurator-group"><strong>Hero</strong><div class="configurator-options"><a href="?hero=split" data-config-key="hero" data-config-value="split">Split</a><a href="?hero=centred" data-config-key="hero" data-config-value="centred">Centred</a><a href="?hero=compact" data-config-key="hero" data-config-value="compact">Compact</a></div></div>
        <div class="configurator-group"><strong>Images</strong><div class="configurator-options"><a href="?images=framed" data-config-key="images" data-config-value="framed">Framed</a><a href="?images=full" data-config-key="images" data-config-value="full">Full-bleed</a><a href="?images=minimal" data-config-key="images" data-config-value="minimal">Minimal</a></div></div>
        <div class="configurator-group"><strong>Sections</strong><div class="configurator-options"><a href="?rhythm=alternating" data-config-key="rhythm" data-config-value="alternating">Alternating</a><a href="?rhythm=plain" data-config-key="rhythm" data-config-value="plain">Plain</a><a href="?rhythm=highlighted" data-config-key="rhythm" data-config-value="highlighted">Highlighted</a><a href="?sections=collapsible" data-config-key="sections" data-config-value="collapsible">Collapsible</a></div></div>
        <div class="configurator-group"><strong>CTA tone</strong><div class="configurator-options"><a href="?cta=direct" data-config-key="cta" data-config-value="direct">Direct</a><a href="?cta=soft" data-config-key="cta" data-config-value="soft">Soft</a><a href="?cta=campaign" data-config-key="cta" data-config-value="campaign">Campaign</a></div></div>
      </div>
    </aside>
  </div>
</section>

<details class="section services-section collapsible-section" open><summary><div class="container"><div class="section-heading"><h2>Example service structure</h2><p>Service content and layout can adapt while the foundation remains maintainable.</p></div></div></summary>
  <div class="container">
    <div class="grid services-grid">
      ${services.slice(0, 4).map(s => `
        <article class="service-card">
          <h3>${s.title || s.name}</h3>
          <p>${s.description || s.blurb || ""}</p>
          ${s.meta ? `<p class="showcase-mode-meta">${s.meta}</p>` : ""}
        </article>
      `).join("")}
    </div>
  </div>
</details>

${projects?.length ? `
<details class="section alt collapsible-section" open><summary><div class="container"><div class="section-heading"><h2>Example project / content blocks</h2><p>Reusable content sections can support different business stories and proof points.</p></div></div></summary>
  <div class="container">
    <div class="grid project-grid">
      ${projects.slice(0, 3).map(p => `
        <article class="project-card">
          <img src="${p.image || "/assets/img/placeholder.webp"}" alt="${p.title}">
          <div class="project-card-body">
            <h3>${p.title}</h3>
            ${p.summary ? `<p>${p.summary}</p>` : ""}
          </div>
        </article>
      `).join("")}
    </div>
  </div>
</details>
` : ""}

<details class="section collapsible-section" open>
  <div class="container starter-docs-grid">
    <div>
      <h2>Profile-switching proof</h2>
      <p>
        This page is not a separate hard-coded website. It is the same starter-kit architecture
        rendering a different profile object. That is the core idea behind Industry Examples.
      </p>
    </div>
    <aside class="starter-panel">
      <h3>Other profiles</h3>
      <ul class="plain-list">
        ${profileList.slice(0, 8).map(profile => `
          <li>
            ${profile.key === (builder?._profileKey || "") 
              ? `<strong>${profile.businessName}</strong>` 
              : `<a href="/showcase-mode/${profile.key}">${profile.businessName}</a>`}
          </li>
        `).join("")}
      </ul>
      <a class="text-link" href="/showcase-mode">View all profiles →</a>
    </aside>
  </div>
</details>
`
}) %>
