<%
  const testimonials = builder?.testimonials || [];
%>

<%- include("./layouts/mainLayout", {
  title: typeof title !== "undefined" ? title : "Proof Notes",
  metaDescription: typeof metaDescription !== "undefined"
    ? metaDescription
    : (builder?.seo?.testimonialsDescription || builder?.seo?.metaDescription || ""),
  builder,
  currentPath: "testimonials",
  body: `
<section class="section">
  <div class="container">
    <h1>Proof Notes</h1>
    <p class="lead">Public-safe trust and testimonial-style content used to show where client evidence belongs in a practical service-business website.</p>

    <div class="testimonials-list">
      ${testimonials.length
        ? testimonials.map(t => `
          <div class="testimonial">
            <p class="quote">"${t.quote}"</p>
            <p class="author">– ${t.author}</p>
          </div>
        `).join("")
        : `<p>No testimonials available yet.</p>`
      }
    </div>
  </div>
</section>
`
}) %>
