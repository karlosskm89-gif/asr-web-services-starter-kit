<%- include("./layouts/mainLayout", {
  title: typeof title !== "undefined" ? title : item.title,
  metaDescription: typeof metaDescription !== "undefined" ? metaDescription : item.summary,
  builder,
  currentPath: "case-studies",
  body: `
<section class="section case-study-detail-hero">
  <div class="container starter-grid">
    <div>
      <p class="eyebrow">${item.category}</p>
      <h1>${item.title}</h1>
      <p class="lead">${item.summary}</p>
      <div class="hero-badges">
        <span>${item.status}</span>
        <span>Public-safe</span>
        <span>Private repo protected</span>
      </div>
    </div>
    <aside class="starter-panel">
      <h2>Highlights</h2>
      <ul class="plain-list">
        ${item.highlights.map(point => `<li>${point}</li>`).join("")}
      </ul>
    </aside>
  </div>
</section>

<section class="section alt">
  <div class="container starter-docs-grid">
    <div>
      <h2>Problem</h2>
      <p>${item.problem}</p>
      <h2>Solution pattern</h2>
      <p>${item.solution}</p>
      <p class="note-card">${item.privacyNote}</p>
    </div>
    <div class="starter-panel">
      <h3>Technology / pattern notes</h3>
      <ul class="tag-list case-study-tags">
        ${item.stack.map(tag => `<li>${tag}</li>`).join("")}
      </ul>
    </div>
  </div>
</section>

<section class="section">
  <div class="container starter-docs-grid">
    <div>
      <h2>How this fits the starter kit</h2>
      <p>The starter kit is the public, reusable version of the same thinking: content-driven structure, practical routing, reusable views, contact/enquiry foundations, documentation, and safe separation between public demo work and private client systems.</p>
    </div>
    <div class="starter-panel">
      <h3>Related public areas</h3>
      <ul class="plain-list">
        <li><a class="text-link" href="/starter-kit">Starter kit overview</a></li>
        <li><a class="text-link" href="/showcase">Fictional showcase examples</a></li>
        <li><a class="text-link" href="/case-studies">Back to case studies</a></li>
      </ul>
    </div>
  </div>
</section>
`
}) %>
