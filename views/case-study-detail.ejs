<%- include("./layouts/mainLayout", {
  title: typeof title !== "undefined" ? title : item.title,
  metaDescription: typeof metaDescription !== "undefined" ? metaDescription : item.summary,
  builder,
  currentPath: "case-studies",
  body: `
<section class="section case-study-detail-hero">
  <div class="container starter-grid">
    <div>
      <p class="eyebrow">${item.category}</p>
      <h1>${item.title}</h1>
      <p class="lead">${item.summary}</p>
      <div class="hero-badges">
        <span>${item.status}</span>
        <span>${item.projectType}</span>
        <span>Public-safe narrative</span>
      </div>
    </div>
    <aside class="starter-panel">
      <h2>Role</h2>
      <p>${item.role}</p>
      ${item.impact ? `<p class="note-card">${item.impact}</p>` : ""}
    </aside>
  </div>
</section>

<section class="section alt">
  <div class="container starter-docs-grid">
    <div>
      <h2>Overview</h2>
      <p>${item.overview}</p>

      <h2>The challenge</h2>
      <p>${item.challenge}</p>

      <h2>Systems philosophy</h2>
      <p>${item.philosophy}</p>
    </div>

    <aside class="starter-panel">
      <h3>Technical scope</h3>
      <ul class="tag-list case-study-tags">
        ${item.stack.map(tag => `<li>${tag}</li>`).join("")}
      </ul>
    </aside>
  </div>
</section>

<section class="section">
  <div class="container starter-docs-grid">
    <div>
      <h2>What was built</h2>
      <ul class="plain-list feature-list">
        ${item.implementation.map(point => `<li>${point}</li>`).join("")}
      </ul>
    </div>

    <div class="starter-panel">
      <h3>Operational outcomes</h3>
      <ul class="plain-list">
        ${item.outcomes.map(point => `<li>${point}</li>`).join("")}
      </ul>
    </div>
  </div>
</section>

<section class="section alt">
  <div class="container starter-docs-grid">
    <div>
      <h2>Key takeaway</h2>
      <p>${item.takeaway}</p>
      <p class="note-card">${item.privacyNote}</p>
    </div>

    <div class="starter-panel">
      <h3>Related public areas</h3>
      <ul class="plain-list">
        <li><a class="text-link" href="/starter-kit">Starter kit overview</a></li>
        <li><a class="text-link" href="/showcase-mode">Showcase Mode</a></li>
        <li><a class="text-link" href="/case-studies">Back to case studies</a></li>
      </ul>
    </div>
  </div>
</section>
`
}) %>
