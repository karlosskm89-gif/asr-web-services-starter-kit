# Active demo profile. The default ASR profile is public-safe and suitable for screenshots.
TEMPLATE_PROFILE=asrWebServices

# Local development port
PORT=3000

# Optional contact form mail settings - leave blank for local/demo use unless configuring email.
SENDGRID_API_KEY=
MAIL_FROM=
MAIL_TO=

# --------------------------------------------------
# Security / cookies (if you later add sessions)
# --------------------------------------------------
# SESSION_SECRET=some-long-random-string

# --------------------------------------------------
# Rate limiting (optional – only if you want env-based)
# --------------------------------------------------
# RATE_MODE=soft
RATE_WINDOW_MS=60000
RATE_MAX=1000

CONTACT_RATE_WINDOW_MS=3600000
CONTACT_RATE_MAX=100
